<%- include('../partials/navbar', { isLoggedIn: true }) %>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<div class="container mt-4 d-flex flex-column align-items-center ">

<div class="row">




<div class="card shadow-sm mb-4">
<div class="card-body">

<h5 class="mb-3">Add Transaction</h5>

<form method="POST" action="/transactions/create">

<div class="row g-2 align-items-end">

<div class="col-md-2">
<label class="form-label">Type</label>
<select name="type" id="typeSelect"
class="form-select" required>
<option value="income">Income</option>
<option value="expense">Expense</option>
<option value="transfer">Transfer</option>
</select>
</div>

<div class="col-md-2" id="singleAccount">
<label class="form-label">Account</label>
<select name="account" class="form-select">
<% accounts.forEach(a => { %>
<option value="<%= a.id %>"><%= a.name %></option>
<% }) %>
</select>
</div>

<div class="col-md-2 d-none" id="fromAccount">
<label class="form-label">From</label>
<select name="fromAccount" class="form-select">
<% accounts.forEach(a => { %>
<option value="<%= a.id %>"><%= a.name %></option>
<% }) %>
</select>
</div>

<div class="col-md-2 d-none" id="toAccount">
<label class="form-label">To</label>
<select name="toAccount" class="form-select">
<% accounts.forEach(a => { %>
<option value="<%= a.id %>"><%= a.name %></option>
<% }) %>
</select>
</div>

<div class="col-md-2">
<label>Amount</label>
<input type="number"
name="amount"
class="form-control"
required>
</div>

<div class="col-md-2">
<label>Category</label>
<input name="category"
class="form-control">
</div>

<div class="col-md-2">
<label>Date</label>
<input type="date"
name="transactionDate"
class="form-control"
required>
</div>

<div class="col-md-2 d-grid">
<button class="btn btn-primary">
Add
</button>
</div>

</div>

</form>

</div>
</div>


</div>



<div class="col-md-8">

<div class="card shadow-sm">
<div class="card-body ">

<h5 style="text-align: center;">Transactions</h5>
<div class="card shadow-sm mb-3">
<div class="card-body">

<form method="GET">
<div class="row g-2">

<div class="col-md-4">
<input
type="text"
name="search"
value="<%= search %>"
class="form-control"
placeholder="Search category...">
</div>

<div class="col-md-3">
<select name="account" class="form-select">
<option value="">All Accounts</option>
<% accounts.forEach(a => { %>
<option value="<%= a.id %>"
<%= selectedAccount==a.id?'selected':'' %>>
<%= a.name %>
</option>
<% }) %>
</select>
</div>

<div class="col-md-3">
<select name="type" class="form-select">
<option value="">All Types</option>
<option value="income" <%= type==='income'?'selected':'' %>>
Income
</option>
<option value="expense" <%= type==='expense'?'selected':'' %>>
Expense
</option>
<option value="transfer" <%= type==='transfer'?'selected':'' %>>
Transfer
</option>
</select>
</div>

<div class="col-md-2 d-grid">
<button class="btn btn-primary">
Filter
</button>
</div>

</div>
</form>

</div>
</div>
<% if(transactions.length === 0){ %>
<p class="text-muted">No transactions yet.</p>
<% } %>

<table class="table table-hover">

<thead class="table-light">
<tr>
<th>Date</th>
<th>From</th>
<th>To</th>
<th>Type</th>
<th>Amount</th>
<th class="text-end">Action</th>
</tr>
</thead>

<tbody>

<% transactions.forEach(t => { 

let fromName = '';
let toName = '';

if(t.type === 'transfer'){
  fromName = t.fromAccount?.name || '-';
  toName = t.toAccount?.name || '-';
}

if(t.type === 'expense'){
  fromName = t.account?.name || '-';
  toName = 'Self';
}

if(t.type === 'income'){
  fromName = 'Self';
  toName = t.account?.name || '-';
}

%>

<tr>

<td>
<%= new Date(t.transactionDate)
.toLocaleDateString() %>
</td>

<td><%= fromName %></td>

<td><%= toName %></td>

<td>
<span class="badge
<%= t.type==='income'
?'bg-success'
:t.type==='expense'
?'bg-danger'
:'bg-primary' %>">
<%= t.type %>
</span>
</td>

<td>₹ <%= t.amount %></td>

<td class="text-end">

<a href="/transactions/<%= t.id %>/edit"
class="btn btn-sm btn-warning">
Edit
</a>

<form method="POST"
action="/transactions/<%= t.id %>/delete"
class="d-inline">

<button class="btn btn-sm btn-danger">
Delete
</button>

</form>

</td>

</tr>

<% }) %>

</tbody>

</table>
<% if(totalPages > 1){ %>
<nav class="mt-3">
<ul class="pagination justify-content-center">

<li class="page-item <%= currentPage===1?'disabled':'' %>">
<a class="page-link"
href="?page=<%= currentPage-1 %>&account=<%= selectedAccount %>&type=<%= type %>&search=<%= search %>">
Prev
</a>
</li>

<% for(let i=1;i<=totalPages;i++){ %>
<li class="page-item <%= i===currentPage?'active':'' %>">
<a class="page-link"
href="?page=<%= i %>&account=<%= selectedAccount %>">
<%= i %>
</a>
</li>
<% } %>

<li class="page-item <%= currentPage===totalPages?'disabled':'' %>">
<a class="page-link"
href="?page=<%= currentPage+1 %>&account=<%= selectedAccount %>">
Next
</a>
</li>

</ul>
</nav>
<% } %>

</div>
</div>

</div>

</div>

</div>
<script>

const typeSelect = document.getElementById('typeSelect');

const single = document.getElementById('singleAccount');
const from = document.getElementById('fromAccount');
const to = document.getElementById('toAccount');

typeSelect.addEventListener('change', () => {

if(typeSelect.value === 'transfer'){
single.classList.add('d-none');
from.classList.remove('d-none');
to.classList.remove('d-none');
}else{
single.classList.remove('d-none');
from.classList.add('d-none');
to.classList.add('d-none');
}

});

</script>